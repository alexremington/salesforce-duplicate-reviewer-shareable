-- Bulk API cannot execute a Salesforce report ID directly.
-- Replace this example with the SOQL equivalent of report 00OVq00000CxYd3MAF,
-- then save it as queries/report-00OVq00000CxYd3MAF.soql.
--
-- Use the report metadata JSON to identify the base object, selected fields,
-- date filter, and report filters. The scheduled wrapper reads the .soql file.

SELECT Id
FROM Contact
