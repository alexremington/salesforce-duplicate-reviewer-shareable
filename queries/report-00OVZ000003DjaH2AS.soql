SELECT
  Id,
  Name,
  FirstName,
  LastName,
  Email,
  Phone,
  MobilePhone,
  Account.Name,
  AccountId,
  MailingStreet,
  MailingCity,
  MailingState,
  MailingPostalCode,
  MailingCountry,
  Title,
  Department,
  LeadSource,
  CreatedDate,
  ziPersonDirectPhone__c,
  ZI_Person_LinkedIn_URL__c
FROM Contact
