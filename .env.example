# Copy this file to .env and fill in values for your own machine.
# .env is ignored by Git.

# Local app server
DUPLICATE_REVIEWER_PORT=5180
HOST=127.0.0.1

# Salesforce CLI authentication for guarded merge actions and helper scripts
SF_ORG_ALIAS=your-org-alias
SF_INSTANCE_URL=https://your-domain.my.salesforce.com
SF_API_VERSION=v67.0
SF_USE_GENERIC_UNIX_KEYCHAIN=true

# Optional direct token for short-lived testing only. Prefer Salesforce CLI auth.
# SF_ACCESS_TOKEN=

# Optional helper-script defaults
# SF_REPORT_ID=report-id-or-key
# SF_SOQL_FILE=/absolute/path/to/query.soql
# OUT_DIR=/absolute/path/to/Output/report-folder
