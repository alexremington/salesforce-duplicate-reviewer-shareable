{
  "name": "salesforce-duplicate-reviewer",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first UI for reviewing Salesforce account and contact duplicate candidates.",
  "scripts": {
    "check": "scripts/check.sh",
    "check:changed": "node ../automation-shared-resources/scripts/check-js-syntax.js . --changed --exclude Output --exclude incoming --exclude logs --exclude node_modules && node ../automation-shared-resources/scripts/check-feature-manifest.js .",
    "check:features": "node ../automation-shared-resources/scripts/check-feature-manifest.js . --strict",
    "check:merge-queue": "node scripts/check-merge-queue-readiness.js",
    "check:windows": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/check-windows.ps1",
    "check:shareable": "scripts/check-shareable.sh",
    "closeout": "node scripts/closeout.js",
    "export:salesforce-duplicate-labels": "node scripts/export-salesforce-duplicate-training-labels.js",
    "export:duplicate-labels": "node scripts/run-salesforce-duplicate-label-export.js",
    "feature:sync-status": "node scripts/sync-feature-status.js",
    "feature:new": "node ../automation-shared-resources/scripts/feature-new.js .",
    "report:contact-model-evaluation": "node scripts/contact-model-evaluation-report.js",
    "sync:shared": "node ../automation-shared-resources/scripts/sync-shared-resources.js .",
    "verify:all": "node ../automation-shared-resources/scripts/managed-app-pipeline.js --tier smoke",
    "verify:fast": "node ../automation-shared-resources/scripts/managed-app-pipeline.js --tier fast --app .",
    "verify:release": "node ../automation-shared-resources/scripts/managed-app-pipeline.js --tier release --app .",
    "verify:smoke": "node ../automation-shared-resources/scripts/managed-app-pipeline.js --tier smoke --app .",
    "setup:playwright": "node vendor/managed-app/scripts/setup-shared-playwright.js",
    "smoke:ui": "node tests/playwright-smoke.js",
    "smoke:ui:local": "node scripts/run-ui-smoke.js",
    "start": "node server/server.js"
  },
  "engines": {
    "node": ">=18"
  }
}
